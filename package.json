{
  "name": "catmandu-fix-js",
  "version": "0.1.0",
  "description": "A JavaScript implementation of the Catmandu Fix language — a small declarative DSL for transforming JSON-like records (with MARC support).",
  "keywords": [
    "catmandu",
    "fix",
    "fix-language",
    "metadata",
    "transformation",
    "dsl",
    "marc",
    "marc21",
    "librecat",
    "json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "author": "Patrick Hochstenbach",
  "license": "MIT",
  "repository": "https://codeberg.org/phochste/catmandu-fix-js.git",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w",
    "prepare": "npm run build",
    "test": "npm run build && node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
